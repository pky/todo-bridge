{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test",
    "build": "pnpm test:auth && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:auth": "vitest run src/__tests__/stores/auth.spec.ts src/__tests__/views/LoginView.spec.ts",
    "test:rules": "firebase emulators:exec --project demo-rertm --only firestore \"vitest run src/__tests__/firestore.rules.test.ts\"",
    "test:e2e": "playwright test",
    "test:responsive": "playwright test e2e/responsive.spec.ts",
    "emulator:start": "firebase emulators:start --only auth,firestore",
    "type-check": "vue-tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "dependencies": {
    "firebase": "^12.8.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^5.0.1"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.5.1",
    "happy-dom": "^20.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.4",
    "wait-on": "^9.0.3"
  }
}
